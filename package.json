{
  "name": "coal-stripes-viz",
  "version": "0.1.0",
  "private": true,
  "description": "Reference app demonstrating the OpenElectricity API: a 'stripes' visualisation of Australian coal power plant capacity factors",
  "author": "Simon Holmes à Court (https://github.com/simonhac)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simonhac/coal-stripes-viz.git"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:local": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "lint:fix": "next lint --fix",
    "check": "npm run typecheck && npm run lint",
    "test": "jest --config jest.config.unit.js",
    "test:integration": "jest --config jest.config.integration.js",
    "test:watch": "jest --config jest.config.unit.js --watch",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@internationalized/date": "^3.8.2",
    "@react-spring/web": "^10.0.1",
    "@tanstack/react-query": "^5.101.2",
    "@use-gesture/react": "^10.3.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "next": "15.5.20",
    "openelectricity": "0.9.1",
    "p-queue": "^9.3.1",
    "p-retry": "^8.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.5.20",
    "jest": "^30.0.4",
    "puppeteer": "^24.14.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.0",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
