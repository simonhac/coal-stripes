# OpenElectricity API Configuration
# Get a free key at https://openelectricity.org.au
OPENELECTRICITY_API_KEY=your_api_key_here

# Secret shared with Vercel Cron to authorise the cache-warming endpoints
# (/api/cron/warm-*). Generate any long random string; set the same value in
# your Vercel project's environment variables.
CRON_SECRET=your_random_secret_here

# Logging Configuration
# Enable file logging for API requests (default: true in development, false in production)
# Set to false when deploying to serverless environments like Vercel
ENABLE_FILE_LOGGING=true
